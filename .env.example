# =============================================================================
# Moto Rental — Variables de entorno
# =============================================================================
# Copia este archivo a `.env.local` y completa los valores.
#
# IMPORTANTE: Si NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY
# NO están configuradas, la app funciona en MODO DEMO usando un almacén de
# datos en memoria con datos semilla (ver src/lib/mock). Esto permite ejecutar
# y demostrar el MVP sin credenciales. Para producción, configura Supabase.
# -----------------------------------------------------------------------------

# Supabase (producción) -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo en servidor. NO exponer al cliente. Necesaria para operaciones admin
# (seed, jobs, bypass RLS). Opcional para el MVP en modo demo.
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp del negocio (formato internacional, solo dígitos, con código país) -
# Ej: 573001234567  -> https://wa.me/573001234567
NEXT_PUBLIC_BUSINESS_WHATSAPP=573001234567

# Nombre del negocio (branding) -----------------------------------------------
NEXT_PUBLIC_BUSINESS_NAME=Moto Rental
